	def validate_empty_file(self):

		for weather in self.weather_data:
			filename = weather["filename"]
			data = weather["data"]

			if os.path.getsize(data) == 0:
				raise Exception(
					f"{file} kosong."
				)

			self.report.add(
				"Empty File",
				"PASS"
			)

			logger.info("semua file memilikii isi.")

